NEBIUS_API_KEY=XXX

# MLflow tracking server (used by the DAG's summarize_and_log step in *standalone* mode).
# In docker-compose this is set to http://mlflow:5000 by the compose file.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=swebench-eval

# --- docker-compose deployment only ---
# Absolute host path of this repo (DockerOperator bind-mounts resolve on the host daemon):
HOST_PROJECT_DIR=/home/youruser/mlops-assignment-e2e-ml-pipeline
# Run the Airflow container as your host user so it can write to runs/  (value: id -u):
AIRFLOW_UID=1000
# Host docker group id so the Airflow container can use the docker socket
# (value: getent group docker | cut -d: -f3):
DOCKER_GID=999

# --- Object storage (S3 / MinIO) ---
# docker-compose wires these to the bundled MinIO automatically. Set them here only
# for *standalone* mode if you run your own MinIO/S3 and want artifact uploads:
# S3_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=mlops-runs
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1
